---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-4 py-20 bg-[#0A0A0F]">
    <!-- Background animated grid -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(#4A148C 1px, transparent 1px), linear-gradient(90deg, #4A148C 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <!-- Floating elements -->
    <div class="absolute top-20 left-10 w-20 h-20 border-2 border-[#00FF41] opacity-20 animate-float" style="animation-delay: 0s;"></div>
    <div class="absolute bottom-32 right-16 w-16 h-16 border-2 border-[#6A1B9A] opacity-30 animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/3 right-1/4 w-12 h-12 border-2 border-[#00FF41] opacity-20 animate-float" style="animation-delay: 2s;"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-4xl mx-auto">
      <div class="animate-fade-in-up flex flex-col items-center">
        <!-- Error Code -->
        <div class="mb-6">
          <h1 class="text-8xl sm:text-9xl md:text-[12rem] font-bold bg-linear-to-r from-[#6A1B9A] via-[#4A148C] to-[#00FF41] bg-clip-text text-transparent leading-none tracking-tight">
            404
          </h1>
        </div>

        <!-- Error Icon -->
        <div class="mb-6 flex justify-center">
          <div class="relative">
            <svg class="w-32 h-32 text-[#00FF41] animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="absolute inset-0 bg-[#00FF41] opacity-20 blur-2xl rounded-full"></div>
          </div>
        </div>

        <!-- Error Message -->
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 text-white text-center">
          Página No Encontrada
        </h2>
        
        <div class="mb-8 text-center">
          <p class="text-[#00FF41] font-mono text-lg sm:text-xl mb-3">
            &lt;Error type="404" /&gt;
          </p>
          <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto px-4 leading-relaxed">
            La página que buscas no existe o ha sido movida. Verifica la URL o regresa al inicio.
          </p>
        </div>

        <!-- Terminal-style error -->
        <div class="w-full max-w-2xl mx-auto mb-10 bg-[#16161D] border border-[#4A148C] rounded-lg overflow-hidden shadow-2xl">
          <div class="bg-[#1A1A24] px-4 py-3 flex items-center gap-2 border-b border-[#4A148C]">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
            <span class="ml-3 text-gray-400 text-sm font-mono">error.log</span>
          </div>
          <div class="p-6 sm:p-8 font-mono text-xs sm:text-sm text-left">
            <div class="text-red-400">
              <span class="text-gray-500">$</span> <span class="text-[#00FF41]">404</span> <span class="text-gray-300">Page not found</span>
            </div>
            <div class="text-gray-500 mt-2">
              → The requested resource does not exist
            </div>
            <div class="text-gray-500 mt-1">
              → Check your URL or return to homepage
            </div>
            <div class="text-[#00FF41] mt-4 animate-pulse">
              █
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md mx-auto">
          <a href="/" class="group relative w-full sm:w-auto px-8 py-4 bg-linear-to-r from-[#4A148C] to-[#6A1B9A] text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[#00FF41]/50 text-center">
            <span class="relative z-10 group-hover:opacity-0 transition-opacity duration-300">Ir al Inicio</span>
            <div class="absolute inset-0 bg-linear-to-r from-[#00FF41] to-[#00CC34] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="absolute inset-0 z-20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-black font-bold">Ir al Inicio →</span>
          </a>
          
          <a href="/#contact" class="w-full sm:w-auto px-8 py-4 border-2 border-[#00FF41] text-[#00FF41] font-semibold rounded-lg transition-all duration-300 hover:bg-[#00FF41] hover:text-black hover:scale-105 text-center">
            Contactar Soporte
          </a>
        </div>

        <!-- Additional Help -->
        <div class="mt-12 text-gray-500 text-sm">
          <p>¿Necesitas ayuda? Código de error: <span class="text-[#00FF41] font-mono">ERR_404_NOT_FOUND</span></p>
        </div>
      </div>
    </div>

    <!-- Glitch effect overlay -->
    <div class="absolute inset-0 pointer-events-none opacity-5">
      <div class="absolute inset-0 bg-[#00FF41] animate-pulse" style="clip-path: polygon(0 20%, 100% 20%, 100% 21%, 0 21%);"></div>
      <div class="absolute inset-0 bg-[#00FF41] animate-pulse" style="clip-path: polygon(0 80%, 100% 80%, 100% 81%, 0 81%); animation-delay: 0.5s;"></div>
    </div>
  </section>
</Layout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
