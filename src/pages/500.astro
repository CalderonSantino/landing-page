---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-4 py-20 bg-[#0A0A0F]">
    <!-- Background animated grid -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(#4A148C 1px, transparent 1px), linear-gradient(90deg, #4A148C 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <!-- Floating elements with error state -->
    <div class="absolute top-20 left-10 w-20 h-20 border-2 border-red-500 opacity-20 animate-float" style="animation-delay: 0s;"></div>
    <div class="absolute bottom-32 right-16 w-16 h-16 border-2 border-red-500 opacity-30 animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/3 right-1/4 w-12 h-12 border-2 border-red-500 opacity-20 animate-float" style="animation-delay: 2s;"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-4xl mx-auto">
      <div class="animate-fade-in-up flex flex-col items-center">
        <!-- Error Code -->
        <div class="mb-6">
          <h1 class="text-8xl sm:text-9xl md:text-[12rem] font-bold bg-linear-to-r from-red-600 via-red-500 to-orange-500 bg-clip-text text-transparent leading-none tracking-tight">
            500
          </h1>
        </div>

        <!-- Error Icon -->
        <div class="mb-6 flex justify-center">
          <div class="relative">
            <svg class="w-32 h-32 text-red-500 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <div class="absolute inset-0 bg-red-500 opacity-20 blur-2xl rounded-full"></div>
          </div>
        </div>

        <!-- Error Message -->
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 text-white text-center">
          Error del Servidor
        </h2>
        
        <div class="mb-8 text-center">
          <p class="text-red-500 font-mono text-base sm:text-lg mb-3 wrap-break-word px-4">
            &lt;Error type="500" status="Internal Server Error" /&gt;
          </p>
          <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto px-4 leading-relaxed">
            Algo salió mal en nuestros servidores. Nuestro equipo ha sido notificado y está trabajando para resolver el problema.
          </p>
        </div>

        <!-- Terminal-style error -->
        <div class="w-full max-w-2xl mx-auto mb-10 bg-[#16161D] border border-red-500/30 rounded-lg overflow-hidden shadow-2xl">
          <div class="bg-[#1A1A24] px-4 py-3 flex items-center gap-2 border-b border-red-500/30">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56] animate-pulse"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F] opacity-30"></div>
            <span class="ml-3 text-gray-400 text-sm font-mono">server.error</span>
          </div>
          <div class="p-6 sm:p-8 font-mono text-xs sm:text-sm text-left">
            <div class="text-red-400">
              <span class="text-gray-500">$</span> <span class="text-red-500">500</span> <span class="text-gray-300">Internal Server Error</span>
            </div>
            <div class="text-gray-500 mt-2">
              → An unexpected error occurred on the server
            </div>
            <div class="text-gray-500 mt-1">
              → Our team has been notified automatically
            </div>
            <div class="text-gray-500 mt-1">
              → Please try again in a few moments
            </div>
            <div class="mt-4 text-red-400">
              <span class="text-gray-500">Stack trace:</span>
            </div>
            <div class="text-gray-600 mt-1 text-xs">
              at ServerError.handler (server.js:127:15)
            </div>
            <div class="text-gray-600 text-xs">
              at processRequest (middleware.js:84:23)
            </div>
            <div class="text-red-500 mt-4 animate-pulse">
              █
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md mx-auto">
          <button onclick="location.reload()" class="group relative w-full sm:w-auto px-8 py-4 bg-linear-to-r from-red-600 to-red-500 text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-red-500/50 text-center">
            <span class="relative z-10 group-hover:opacity-0 transition-opacity duration-300">Reintentar</span>
            <div class="absolute inset-0 bg-linear-to-r from-orange-500 to-red-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="absolute inset-0 z-20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-black font-bold">Reintentar ↻</span>
          </button>
          
          <a href="/" class="w-full sm:w-auto px-8 py-4 border-2 border-[#00FF41] text-[#00FF41] font-semibold rounded-lg transition-all duration-300 hover:bg-[#00FF41] hover:text-black hover:scale-105 text-center">
            Ir al Inicio
          </a>
        </div>

        <!-- Additional Help -->
        <div class="mt-12 text-gray-500 text-sm">
          <p>Si el problema persiste, contacta a soporte.</p>
          <p class="mt-2">Código de error: <span class="text-red-500 font-mono">ERR_500_INTERNAL_SERVER</span></p>
        </div>
      </div>
    </div>

    <!-- Glitch effect overlay -->
    <div class="absolute inset-0 pointer-events-none opacity-10">
      <div class="absolute inset-0 bg-red-500 animate-pulse" style="clip-path: polygon(0 30%, 100% 30%, 100% 31%, 0 31%);"></div>
      <div class="absolute inset-0 bg-red-500 animate-pulse" style="clip-path: polygon(0 60%, 100% 60%, 100% 61%, 0 61%); animation-delay: 0.3s;"></div>
      <div class="absolute inset-0 bg-red-500 animate-pulse" style="clip-path: polygon(0 90%, 100% 90%, 100% 91%, 0 91%); animation-delay: 0.6s;"></div>
    </div>
  </section>
</Layout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
