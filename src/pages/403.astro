---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-4 py-20 bg-[#0A0A0F]">
    <!-- Background animated grid -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(#4A148C 1px, transparent 1px), linear-gradient(90deg, #4A148C 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <!-- Floating elements with warning state -->
    <div class="absolute top-20 left-10 w-20 h-20 border-2 border-yellow-500 opacity-20 animate-float" style="animation-delay: 0s;"></div>
    <div class="absolute bottom-32 right-16 w-16 h-16 border-2 border-yellow-500 opacity-30 animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/3 right-1/4 w-12 h-12 border-2 border-yellow-500 opacity-20 animate-float" style="animation-delay: 2s;"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-4xl mx-auto">
      <div class="animate-fade-in-up flex flex-col items-center">
        <!-- Error Code -->
        <div class="mb-6">
          <h1 class="text-8xl sm:text-9xl md:text-[12rem] font-bold bg-linear-to-r from-yellow-600 via-yellow-500 to-orange-500 bg-clip-text text-transparent leading-none tracking-tight">
            403
          </h1>
        </div>

        <!-- Error Icon -->
        <div class="mb-6 flex justify-center">
          <div class="relative">
            <svg class="w-32 h-32 text-yellow-500 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            <div class="absolute inset-0 bg-yellow-500 opacity-20 blur-2xl rounded-full"></div>
          </div>
        </div>

        <!-- Error Message -->
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 text-white text-center">
          Acceso Prohibido
        </h2>
        
        <div class="mb-8 text-center">
          <p class="text-yellow-500 font-mono text-base sm:text-lg mb-3 wrap-break-word px-4">
            &lt;Error type="403" status="Forbidden" /&gt;
          </p>
          <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto px-4 leading-relaxed">
            No tienes permisos para acceder a este recurso. Si crees que esto es un error, contacta al administrador.
          </p>
        </div>

        <!-- Terminal-style error -->
        <div class="w-full max-w-2xl mx-auto mb-10 bg-[#16161D] border border-yellow-500/30 rounded-lg overflow-hidden shadow-2xl">
          <div class="bg-[#1A1A24] px-4 py-3 flex items-center gap-2 border-b border-yellow-500/30">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E] animate-pulse"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
            <span class="ml-3 text-gray-400 text-sm font-mono">access.denied</span>
          </div>
          <div class="p-6 sm:p-8 font-mono text-xs sm:text-sm text-left">
            <div class="text-yellow-400">
              <span class="text-gray-500">$</span> <span class="text-yellow-500">403</span> <span class="text-gray-300">Forbidden</span>
            </div>
            <div class="text-gray-500 mt-2">
              → Access to this resource is restricted
            </div>
            <div class="text-gray-500 mt-1">
              → Authentication required or insufficient permissions
            </div>
            <div class="text-gray-500 mt-1">
              → Contact administrator if you need access
            </div>
            <div class="mt-4 text-yellow-400">
              <span class="text-gray-500">Required permissions:</span>
            </div>
            <div class="text-gray-600 mt-1 text-xs">
              ❌ admin.access
            </div>
            <div class="text-gray-600 text-xs">
              ❌ resource.read
            </div>
            <div class="text-yellow-500 mt-4 animate-pulse">
              █
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md mx-auto">
          <a href="/" class="group relative w-full sm:w-auto px-8 py-4 bg-linear-to-r from-[#4A148C] to-[#6A1B9A] text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[#00FF41]/50 text-center">
            <span class="relative z-10 group-hover:opacity-0 transition-opacity duration-300">Ir al Inicio</span>
            <div class="absolute inset-0 bg-linear-to-r from-[#00FF41] to-[#00CC34] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="absolute inset-0 z-20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-black font-bold">Ir al Inicio →</span>
          </a>
          
          <a href="/#contact" class="w-full sm:w-auto px-8 py-4 border-2 border-yellow-500 text-yellow-500 font-semibold rounded-lg transition-all duration-300 hover:bg-yellow-500 hover:text-black hover:scale-105 text-center">
            Solicitar Acceso
          </a>
        </div>

        <!-- Additional Help -->
        <div class="mt-12 text-gray-500 text-sm">
          <p>¿Necesitas acceso? Contacta al administrador del sistema.</p>
          <p class="mt-2">Código de error: <span class="text-yellow-500 font-mono">ERR_403_FORBIDDEN</span></p>
        </div>
      </div>
    </div>

    <!-- Lock pattern overlay -->
    <div class="absolute inset-0 pointer-events-none opacity-5">
      <div class="absolute inset-0 bg-yellow-500 animate-pulse" style="clip-path: polygon(0 40%, 100% 40%, 100% 41%, 0 41%);"></div>
      <div class="absolute inset-0 bg-yellow-500 animate-pulse" style="clip-path: polygon(0 70%, 100% 70%, 100% 71%, 0 71%); animation-delay: 0.4s;"></div>
    </div>
  </section>
</Layout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
