---
// Services Section - Servicios ofrecidos
const services = [
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
    </svg>`,
    title: "ERPs Empresariales",
    description: "Sistemas de planificación empresarial personalizados para optimizar tus procesos de negocio."
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
    </svg>`,
    title: "CRM Solutions",
    description: "Gestión de relaciones con clientes para maximizar ventas y mejorar la experiencia del usuario."
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
    </svg>`,
    title: "Páginas Web",
    description: "Desarrollo de sitios web modernos, rápidos y optimizados para conversión y SEO."
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
    </svg>`,
    title: "Apps Móviles",
    description: "Aplicaciones nativas para iOS y Android con rendimiento excepcional."
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
    </svg>`,
    title: "Cloud & AWS",
    description: "Infraestructura en la nube escalable y segura con AWS para tu negocio."
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
    </svg>`,
    title: "Bases de Datos",
    description: "Diseño e implementación de bases de datos robustas con PostgreSQL y más."
  }
];
---

<section id="services" class="py-24 px-4 bg-linear-to-b from-[#0A0A0F] to-[#16161D]">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 bg-linear-to-r from-[#00FF41] to-[#6A1B9A] bg-clip-text text-transparent">
        Nuestros Servicios
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Soluciones tecnológicas integrales para impulsar tu negocio al siguiente nivel
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <div 
          class="group relative bg-[#16161D] border border-[#4A148C] rounded-lg p-8 transition-all duration-300 hover:border-[#00FF41] hover:transform hover:scale-105 hover:shadow-xl hover:shadow-[#00FF41]/20"
          style={`animation: fadeInUp 0.8s ease-out ${index * 0.1}s backwards;`}
        >
          <!-- Icon -->
          <div class="text-[#00FF41] mb-4 group-hover:text-[#4A148C] transition-colors duration-300">
            <Fragment set:html={service.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#00FF41] transition-colors duration-300">
            {service.title}
          </h3>
          <p class="text-gray-400 leading-relaxed">
            {service.description}
          </p>

          <!-- Hover effect border -->
          <div class="absolute inset-0 border-2 border-transparent rounded-lg group-hover:border-[#00FF41] opacity-0 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <p class="text-gray-300 mb-6 text-lg">
        ¿Tienes un proyecto en mente?
      </p>
      <a 
        href="#contact" 
        class="inline-block px-8 py-4 bg-linear-to-r from-[#4A148C] to-[#6A1B9A] text-white font-semibold rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[#00FF41]/50"
      >
        Contactanos Ahora
      </a>
    </div>
  </div>
</section>
