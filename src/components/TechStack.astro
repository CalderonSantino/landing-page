---
// Tech Stack Section - Tecnologías que dominamos
const technologies = [
  { name: "HTML5", color: "#E34F26" },
  { name: "CSS3", color: "#1572B6" },
  { name: "JavaScript", color: "#F7DF1E" },
  { name: "TypeScript", color: "#3178C6" },
  { name: "Astro", color: "#FF5D01" },
  { name: "Tailwind", color: "#06B6D4" },
  { name: "Node.js", color: "#339933" },
  { name: "Next.js", color: "#000000" },
  { name: "PostgreSQL", color: "#4169E1" },
  { name: "AWS", color: "#FF9900" }
];
---

<section id="tech" class="py-24 px-4 bg-[#0A0A0F] relative overflow-hidden">
  <!-- Background effect -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#4A148C] rounded-full filter blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#00FF41] rounded-full filter blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 bg-linear-to-r from-[#6A1B9A] to-[#00FF41] bg-clip-text text-transparent">
        Tech Stack
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Utilizamos las tecnologías más modernas y robustas del mercado
      </p>
      <div class="mt-4 text-[#00FF41] font-mono">
        <span class="animate-pulse">{'<'}</span>code<span class="animate-pulse">{'>'}</span>
      </div>
    </div>

    <!-- Technologies Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 mb-16">
      {technologies.map((tech, index) => (
        <div 
          class="group relative bg-[#16161D] border border-[#4A148C] rounded-lg p-6 flex flex-col items-center justify-center transition-all duration-300 hover:border-[#00FF41] hover:transform hover:scale-110 hover:shadow-xl cursor-pointer"
          style={`animation: slideInRight ${0.5 + index * 0.1}s ease-out backwards;`}
        >
          <!-- Tech Name -->
          <div 
            class="text-2xl font-bold mb-2 transition-colors duration-300"
            style={`color: ${tech.color};`}
          >
            &lt;/&gt;
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-[#00FF41] transition-colors duration-300 text-center">
            {tech.name}
          </h3>
          
          <!-- Glow effect on hover -->
          <div 
            class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-30 transition-opacity duration-300 blur-xl"
            style={`background-color: ${tech.color};`}
          ></div>
        </div>
      ))}
    </div>

    <!-- Code Block Showcase -->
    <div class="max-w-4xl mx-auto bg-[#16161D] border border-[#4A148C] rounded-lg overflow-hidden shadow-2xl">
      <!-- Terminal Header -->
      <div class="bg-[#1A1A24] px-4 py-3 flex items-center gap-2 border-b border-[#4A148C]">
        <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
        <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
        <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
        <span class="ml-4 text-gray-400 text-sm font-mono">stack.ts</span>
      </div>

      <!-- Code Content -->
      <div class="p-6 font-mono text-sm overflow-x-auto">
        <pre class="text-gray-300"><code><span class="text-[#C678DD]">const</span> <span class="text-[#E06C75]">techStack</span> <span class="text-white">=</span> <span class="text-white">{'{'}</span>
  <span class="text-[#00FF41]">frontend</span><span class="text-white">:</span> <span class="text-white">[</span><span class="text-[#98C379]">'Astro'</span><span class="text-white">,</span> <span class="text-[#98C379]">'Next.js'</span><span class="text-white">,</span> <span class="text-[#98C379]">'Tailwind'</span><span class="text-white">],</span>
  <span class="text-[#00FF41]">backend</span><span class="text-white">:</span> <span class="text-white">[</span><span class="text-[#98C379]">'Node.js'</span><span class="text-white">,</span> <span class="text-[#98C379]">'TypeScript'</span><span class="text-white">],</span>
  <span class="text-[#00FF41]">database</span><span class="text-white">:</span> <span class="text-white">[</span><span class="text-[#98C379]">'PostgreSQL'</span><span class="text-white">],</span>
  <span class="text-[#00FF41]">cloud</span><span class="text-white">:</span> <span class="text-white">[</span><span class="text-[#98C379]">'AWS'</span><span class="text-white">],</span>
  <span class="text-[#00FF41]">mobile</span><span class="text-white">:</span> <span class="text-white">[</span><span class="text-[#98C379]">'iOS'</span><span class="text-white">,</span> <span class="text-[#98C379]">'Android'</span><span class="text-white">]</span>
<span class="text-white">{'}'}</span><span class="text-white">;</span>

<span class="text-[#C678DD]">export</span> <span class="text-[#C678DD]">default</span> <span class="text-[#E06C75]">techStack</span><span class="text-white">;</span></code></pre>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <p class="text-gray-300 text-lg mb-2">
        ¿Necesitas una tecnología específica?
      </p>
      <p class="text-[#00FF41] font-semibold">
        También trabajamos con muchas otras herramientas y frameworks
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
