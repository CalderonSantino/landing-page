---                            
import '../styles/global.css'
---  

<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-4">
  <!-- Background animated grid -->
  <div class="absolute inset-0 opacity-20">
    <div class="absolute inset-0" style="background-image: linear-gradient(#4A148C 1px, transparent 1px), linear-gradient(90deg, #4A148C 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>

  <!-- Floating elements -->
  <div class="absolute top-20 left-10 w-20 h-20 border-2 border-[#00FF41] opacity-20 animate-float" style="animation-delay: 0s;"></div>
  <div class="absolute bottom-32 right-16 w-16 h-16 border-2 border-[#6A1B9A] opacity-30 animate-float" style="animation-delay: 1s;"></div>
  <div class="absolute top-1/3 right-1/4 w-12 h-12 border-2 border-[#00FF41] opacity-20 animate-float" style="animation-delay: 2s;"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto text-center">
    <div class="animate-fade-in-up">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-linear-to-r from-[#6A1B9A] via-[#4A148C] to-[#00FF41] bg-clip-text text-transparent">
        DevStack Studio
      </h1>
      <p class="text-xl md:text-2xl text-[#00FF41] mb-20 font-light tracking-wide">
        &lt;/&gt; Estudio Freelance de Desarrollo Web
      </p>
      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed">
        Soy Santino, desarrollador freelance y fundador de DevStack Studio. Ayudo a negocios, profesionales y equipos a crear landing pages, sitios web y aplicaciones a medida con foco en rendimiento, claridad y resultados.
      </p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-12 animate-fade-in-up" style="animation-delay: 0.3s;">
      <a href="#contact" class="group relative px-8 py-4 bg-linear-to-r from-[#4A148C] to-[#6A1B9A] text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[#00FF41]/50">
        <span class="relative z-10 group-hover:opacity-0 transition-opacity duration-300">Trabajemos Juntos</span>
        <div class="absolute inset-0 bg-linear-to-r from-[#00FF41] to-[#00CC34] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <span class="absolute inset-0 z-20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-black font-bold">Trabajemos Juntos -></span>
      </a>
      
      <a href="#services" class="px-8 py-4 border-2 border-[#00FF41] text-[#00FF41] font-semibold rounded-lg transition-all duration-300 hover:bg-[#00FF41] hover:text-black hover:scale-105">
        Ver Servicios
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 max-w-4xl mx-auto">
      <div class="animate-fade-in-up" style="animation-delay: 0.4s;">
        <div class="text-4xl font-bold text-[#00FF41] mb-2">10+</div>
        <div class="text-gray-400 text-sm">Proyectos realizados</div>
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.5s;">
        <div class="text-4xl font-bold text-[#00FF41] mb-2">1:1</div>
        <div class="text-gray-400 text-sm">Atencion directa</div>
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.6s;">
        <div class="text-4xl font-bold text-[#00FF41] mb-2">MVP</div>
        <div class="text-gray-400 text-sm">Entrega por etapas</div>
      </div>
      <div class="animate-fade-in-up" style="animation-delay: 0.7s;">
        <div class="text-4xl font-bold text-[#00FF41] mb-2">10+</div>
        <div class="text-gray-400 text-sm">Tecnologias</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-[#00FF41]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  @keyframes bounce {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(-10px);
    }
  }
</style>
