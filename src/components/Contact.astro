---
// Contact Section - Contacto
const whatsappHref = "https://wa.me/5493492373900?text=Hola%20Santino%2C%20quiero%20consultarte%20por%20un%20proyecto%20para%20DevStack%20Studio.";
const scheduleHref = "mailto:hola@devstack.studio?subject=Agendar%20llamada&body=Hola%20Santino%2C%20quiero%20coordinar%20una%20llamada%20para%20hablar%20sobre%20un%20proyecto.";
---

<section id="contact" class="py-24 px-4 bg-linear-to-b from-[#16161D] to-[#0A0A0F] relative overflow-hidden">
  <!-- Animated background elements -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 right-10 w-64 h-64 border border-[#00FF41] rounded-full animate-float"></div>
    <div class="absolute bottom-20 left-20 w-48 h-48 border border-[#4A148C] rounded-full animate-float" style="animation-delay: 1s;"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 bg-linear-to-r from-[#00FF41] to-[#6A1B9A] bg-clip-text text-transparent">
        Comencemos tu Proyecto
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Contame que queres construir y te respondo personalmente desde DevStack Studio.
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Side - Info -->
      <div class="space-y-8">
        <div class="animate-fade-in-up">
          <h3 class="text-2xl font-bold text-white mb-6">
            Como trabajo cada proyecto
          </h3>
          
          <div class="space-y-6">
            <!-- Feature 1 -->
            <div class="flex items-start gap-4 group">
              <div class="shrink-0 w-12 h-12 bg-[#4A148C] rounded-lg flex items-center justify-center group-hover:bg-[#00FF41] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#00FF41] group-hover:text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white font-semibold mb-1">Desarrollo agil</h4>
                <p class="text-gray-400 text-sm">Entregas claras, iterativas y con feedback frecuente</p>
              </div>
            </div>

            <!-- Feature 2 -->
            <div class="flex items-start gap-4 group">
              <div class="shrink-0 w-12 h-12 bg-[#4A148C] rounded-lg flex items-center justify-center group-hover:bg-[#00FF41] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#00FF41] group-hover:text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white font-semibold mb-1">Codigo de calidad</h4>
                <p class="text-gray-400 text-sm">Buenas practicas, estructura mantenible y foco en rendimiento</p>
              </div>
            </div>

            <!-- Feature 3 -->
            <div class="flex items-start gap-4 group">
              <div class="shrink-0 w-12 h-12 bg-[#4A148C] rounded-lg flex items-center justify-center group-hover:bg-[#00FF41] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#00FF41] group-hover:text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white font-semibold mb-1">Acompanamiento</h4>
                <p class="text-gray-400 text-sm">Soporte posterior al lanzamiento y mejoras por etapas</p>
              </div>
            </div>

            <!-- Feature 4 -->
            <div class="flex items-start gap-4 group">
              <div class="shrink-0 w-12 h-12 bg-[#4A148C] rounded-lg flex items-center justify-center group-hover:bg-[#00FF41] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#00FF41] group-hover:text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white font-semibold mb-1">Precios Competitivos</h4>
                <p class="text-gray-400 text-sm">Alcance claro y maximo valor por tu inversion</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - CTA Card -->
      <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="bg-[#16161D] border-2 border-[#4A148C] rounded-2xl p-8 hover:border-[#00FF41] transition-all duration-300 hover:shadow-2xl hover:shadow-[#00FF41]/20">
          <div class="text-center mb-8">
            <div class="inline-block p-4 bg-[#4A148C] rounded-full mb-4 animate-glow">
              <svg class="w-12 h-12 text-[#00FF41]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">
              Contactame
            </h3>
            <p class="text-gray-400">
              Te leo y coordinamos una consulta inicial
            </p>
          </div>

          <!-- Contact Methods -->
          <div class="space-y-4">
            <a href="mailto:hola@devstack.studio" class="block w-full px-6 py-4 bg-linear-to-r from-[#4A148C] to-[#6A1B9A] text-white font-semibold rounded-lg text-center transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[#00FF41]/50">
              hola@devstack.studio
            </a>
            
            <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="block w-full px-6 py-4 border-2 border-[#00FF41] text-[#00FF41] font-semibold rounded-lg text-center transition-all duration-300 hover:bg-[#00FF41] hover:text-black hover:scale-105">
              WhatsApp
            </a>
            
            <a href={scheduleHref} class="block w-full px-6 py-4 border-2 border-[#6A1B9A] text-[#6A1B9A] font-semibold rounded-lg text-center transition-all duration-300 hover:bg-[#6A1B9A] hover:text-white hover:scale-105">
              Agendar Llamada
            </a>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-[#0A0A0F] border-t border-[#4A148C] py-8 px-4">
  <div class="max-w-6xl mx-auto text-center">
    <p class="text-gray-400 mb-2">
      <span class="text-[#00FF41] font-mono">&lt;/&gt;</span> 
      DevStack Studio | devstack.studio
    </p>
    <p class="text-gray-500 text-sm">
      (c) 2025 DevStack Studio. Todos los derechos reservados.
    </p>
  </div>
</footer>
